{
  "name": "data-bartender",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:first-install": "VITE_SIMULATE_FIRST_INSTALL=true vite",
    "dev:friend": "VITE_FRIEND_MODE=true vite",
    "dev:friend:first-install": "VITE_FRIEND_MODE=true VITE_SIMULATE_FIRST_INSTALL=true vite",
    "build": "tsc && vite build",
    "build:first-install": "VITE_SIMULATE_FIRST_INSTALL=true tsc && VITE_SIMULATE_FIRST_INSTALL=true vite build",
    "build:friend": "VITE_FRIEND_MODE=true tsc && VITE_FRIEND_MODE=true vite build",
    "build:friend:first-install": "VITE_FRIEND_MODE=true VITE_SIMULATE_FIRST_INSTALL=true tsc && VITE_FRIEND_MODE=true VITE_SIMULATE_FIRST_INSTALL=true vite build",
    "preview": "vite preview",
    "tauri": "PATH=/opt/homebrew/opt/rustup/bin:$PATH tauri",
    "tauri:dev": "VITE_SIMULATE_FIRST_INSTALL=false npm run tauri -- dev",
    "tauri:dev:first-install": "VITE_SIMULATE_FIRST_INSTALL=true npm run tauri -- dev",
    "tauri:dev:friend": "VITE_FRIEND_MODE=true VITE_SIMULATE_FIRST_INSTALL=false npm run tauri -- dev",
    "tauri:dev:friend:first-install": "VITE_FRIEND_MODE=true VITE_SIMULATE_FIRST_INSTALL=true npm run tauri -- dev",
    "cargo:check": "cd src-tauri && PATH=/opt/homebrew/opt/rustup/bin:$PATH cargo check",
    "mcp:dev": "tsx src/mcp/server.ts",
    "mcp:sse": "tsx src/mcp/server.ts --sse"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.40.0",
    "openai": "^6.33.0",
    "pixelarticons": "^2.1.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "shadcn": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4",
    "zod": "^4.3.6"
  }
}
