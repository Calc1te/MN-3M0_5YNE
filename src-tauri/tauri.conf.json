{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MN-3M0_5YNE",
  "version": "0.1.0",
  "identifier": "com.calcite.mn-3mo-5yne",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MN-3M0_5YNE",
        "label": "main",
        "width": 800,
        "height": 600,
        "decorations": false,
        "shadow": false,
        "acceptFirstMouse": true,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
